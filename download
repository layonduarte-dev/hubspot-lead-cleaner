# Propriedades-alvo do HubSpot e os sinônimos que devem ser reconhecidos
# nos cabeçalhos da planilha de entrada. As chaves são as propriedades
# finais; os valores são variações que o fuzzy-matcher deve reconhecer.
# A comparação é feita sem acento, em minúsculas e ignorando pontuação.
header_synonyms:
  Nome:
    - nome
    - first name
    - firstname
    - primeiro nome
    - nome do contato
    - contato
    - cliente
    - lead
  Sobrenome:
    - sobrenome
    - last name
    - lastname
    - ultimo nome
    - apelido
  Email:
    - email
    - e-mail
    - e mail
    - endereco de email
    - email do contato
    - mail
    - correio eletronico
  Número de Telefone:
    - telefone
    - numero de telefone
    - numero
    - celular
    - whatsapp
    - whats
    - fone
    - phone
    - phone number
    - contato telefonico
  Nome da Empresa:
    - empresa
    - nome da empresa
    - company
    - company name
    - organizacao
    - razao social
    - corporacao
  Cargo:
    - cargo
    - funcao
    - job title
    - jobtitle
    - title
    - posicao
    - ocupacao
    - role
  Cargo RH:
    - cargo rh
    - cargo de rh
    - area rh
    - perfil rh
    - cargo solides
  Faixa de Colaboradores:
    - faixa de colaboradores
    - numero de funcionarios
    - num funcionarios
    - qtd funcionarios
    - quantidade de funcionarios
    - tamanho da empresa
    - company size
    - employees
    - porte da empresa
    - colaboradores

# Limite de similaridade (0..1) para aceitar uma correspondência aproximada
# de cabeçalho que não esteja na lista de sinônimos exatos.
fuzzy_threshold: 0.82

# Correções automáticas de domínios escritos errado.
# A chave é o domínio errado (depois do @), o valor é o correto.
domain_typos:
